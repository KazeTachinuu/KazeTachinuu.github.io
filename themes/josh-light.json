{
  "name": "josh-light",
  "type": "light",
  "colors": {
    "editor.background": "#E8F1FC",
    "editor.foreground": "#2A2A2A",
    "editorLineNumber.foreground": "#8b95a7",
    "editorLineNumber.activeForeground": "#4a5568"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#467790", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#651FFF" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#BF00B8" }
    },
    {
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined", "constant.language"],
      "settings": { "foreground": "#BF00B8" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#AA00FF" }
    },
    {
      "scope": ["keyword.control.conditional", "keyword.control.flow", "keyword.control.loop"],
      "settings": { "foreground": "#651FFF" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison", "keyword.operator.logical", "keyword.operator.ternary", "keyword.operator.spread", "keyword.operator.rest", "keyword.operator.expression", "keyword.operator.arrow"],
      "settings": { "foreground": "#AA00FF" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#3D5AFE", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#2A2A2A" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#DA0079" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#3D5AFE" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#2A2A2A" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#2A2A2A" }
    },
    {
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property"],
      "settings": { "foreground": "#DA0079", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#000000" }
    },
    {
      "scope": ["meta.property-name", "support.type.property-name"],
      "settings": { "foreground": "#DA0079" }
    },
    {
      "scope": ["meta.selector", "entity.other.attribute-name.class"],
      "settings": { "foreground": "#AA00FF" }
    },
    {
      "scope": ["entity.other.attribute-name.id"],
      "settings": { "foreground": "#AA00FF" }
    },
    {
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#BF00B8" }
    },
    {
      "scope": ["constant.other"],
      "settings": { "foreground": "#BF00B8" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#651FFF" }
    },
    {
      "scope": ["punctuation.definition.template-expression"],
      "settings": { "foreground": "#AA00FF" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#3D5AFE", "fontStyle": "bold" }
    },
    {
      "scope": ["variable.language.this", "variable.language.super"],
      "settings": { "foreground": "#AA00FF" }
    },
    {
      "scope": ["keyword.operator.new"],
      "settings": { "foreground": "#AA00FF" }
    }
  ]
}
