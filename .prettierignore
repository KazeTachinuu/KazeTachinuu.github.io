# Prettier mangles MDX comments — converts {/* */} to {/_ _/} because it
# sees the asterisks as italic markers. Skip MDX entirely; format manually.
*.mdx
*.md

# Astro single-file components need prettier-plugin-astro (not installed).
# Without the plugin, prettier errors out instead of skipping silently.
*.astro

# Build/lock files don't need formatting.
dist/
node_modules/
bun.lock
package-lock.json
