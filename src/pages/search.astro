---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Search" mainClass="search-page">
  <header class="search-header">
    <p class="label mb-3">search</p>
    <h1 class="text-4xl font-medium tracking-tight text-page">Search</h1>
    <p class="mt-3 text-lg text-muted">Find articles, writeups, snippets, and more.</p>
  </header>

  <div class="search-input-wrap">
    <svg class="search-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input
      id="search-input"
      type="search"
      placeholder="Type to search…"
      autocomplete="off"
      autocapitalize="none"
      spellcheck="false"
      autofocus
    />
    <button id="search-clear" class="search-clear" type="button" hidden>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div id="search-meta" class="search-meta" hidden></div>
  <div id="search-results" class="search-results"></div>
  <noscript><p class="search-empty">Search requires JavaScript.</p></noscript>
</Layout>

<script is:inline type="module">
  var input = document.getElementById('search-input');
  var clearBtn = document.getElementById('search-clear');
  var meta = document.getElementById('search-meta');
  var resultsEl = document.getElementById('search-results');
  if (!input || !resultsEl) throw new Error('missing DOM');

  var pagefind = null;
  var debounceTimer;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    pagefind = await import('/pagefind/pagefind.js');
    await pagefind.init();
    return pagefind;
  }

  async function renderResults(results, query) {
    if (!results || !results.length) {
      meta.hidden = true;
      resultsEl.textContent = '';
      if (query) {
        var p = document.createElement('p');
        p.className = 'search-no-results';
        p.textContent = 'No results for \u201c' + query + '\u201d';
        resultsEl.appendChild(p);
      }
      return;
    }

    meta.hidden = false;
    meta.textContent = results.length + ' result' + (results.length === 1 ? '' : 's');

    var items = await Promise.all(results.slice(0, 20).map(function(r) { return r.data(); }));
    resultsEl.textContent = '';

    for (var item of items) {
      var card = document.createElement('a');
      card.className = 'search-result';
      card.href = item.url;

      var title = document.createElement('h2');
      title.className = 'search-result-title';
      title.textContent = (item.meta && item.meta.title) || 'Untitled';
      card.appendChild(title);

      if (item.excerpt) {
        var excerpt = document.createElement('p');
        excerpt.className = 'search-result-excerpt';
        excerpt.innerHTML = item.excerpt;
        card.appendChild(excerpt);
      }

      if (item.sub_results && item.sub_results.length > 1) {
        var subs = document.createElement('div');
        subs.className = 'search-sub-results';
        for (var sub of item.sub_results.slice(0, 3)) {
          if (sub.url === item.url && sub.title === (item.meta && item.meta.title)) continue;
          var link = document.createElement('a');
          link.className = 'search-sub-link';
          link.href = sub.url;

          var arrow = document.createElement('span');
          arrow.className = 'search-sub-arrow';
          arrow.textContent = '\u21B3';
          link.appendChild(arrow);

          var subTitle = document.createElement('span');
          subTitle.textContent = sub.title;
          link.appendChild(subTitle);

          subs.appendChild(link);
        }
        if (subs.children.length) card.appendChild(subs);
      }

      resultsEl.appendChild(card);
    }
  }

  async function doSearch(query) {
    if (!query) {
      meta.hidden = true;
      resultsEl.textContent = '';
      clearBtn.hidden = true;
      return;
    }
    clearBtn.hidden = false;
    try {
      var pf = await loadPagefind();
      var search = await pf.search(query);
      renderResults(search.results, query);
    } catch (e) {
      meta.hidden = true;
      resultsEl.textContent = '';
      var p = document.createElement('p');
      p.className = 'search-empty';
      p.textContent = 'Search index not available \u2014 run bun build first.';
      resultsEl.appendChild(p);
    }
  }

  input.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function() { doSearch(input.value.trim()); }, 200);
  });

  clearBtn.addEventListener('click', function() {
    input.value = '';
    input.focus();
    doSearch('');
  });

  // Prefill from ?q= param
  var q = new URLSearchParams(location.search).get('q');
  if (q) {
    input.value = q;
    doSearch(q);
  }
</script>
