---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/Layout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import ArticleHeader from '~/components/ArticleHeader.astro';
import ArticleFooter from '~/components/ArticleFooter.astro';
import TableOfContents from '~/components/TableOfContents.astro';
import ArticleLikes from '~/components/ArticleLikes.astro';
import * as MDX from '~/components/mdx';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', (e) => !e.data.draft);
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, headings } = await render(post);

const category = post.data.categories[0]
  ? post.data.categories[0].charAt(0).toUpperCase() + post.data.categories[0].slice(1)
  : 'Blog';
---

<Layout title={post.data.title} description={post.data.description} mainClass="article-layout px-6 py-16">
  <div class="article-main">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: post.data.title },
    ]} />

    <ArticleHeader
      title={post.data.title}
      category={category}
      date={post.data.date}
      description={post.data.description}
    />

    <article class="prose prose-lg dark:prose-invert max-w-none">
      <Content components={MDX} />
    </article>

    <ArticleFooter slug={`blog/${post.id}`} date={post.data.date} updated={post.data.updated} />
  </div>

  <aside class="article-sidebar">
    <TableOfContents headings={headings} />
    <ArticleLikes slug={`blog/${post.id}`} />
  </aside>
</Layout>
