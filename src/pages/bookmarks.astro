---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/PageHeader.astro';
import { BOOKMARKS } from '~/data/bookmarks';

const total = BOOKMARKS.reduce((n, c) => n + c.bookmarks.length, 0);
---

<Layout title="Bookmarks" mainClass="max-w-4xl mx-auto px-6 py-16">
  <PageHeader
    title="Bookmarks"
    section="bookmarks"
    description={`${total} single-purpose, open-source tools I actually use.`}
  />

  <div class="bookmark-grid">
    {BOOKMARKS.map((cat) => (
      <section class="bookmark-section">
        <h2 class="bookmark-section-title">{cat.title}</h2>
        <ul class="bookmark-list">
          {cat.bookmarks.map((b) => (
            <li>
              <a class="bookmark-link" href={b.url} target="_blank" rel="noopener noreferrer">
                <span class="bookmark-name">{b.name}</span>
                <span class="bookmark-arrow" aria-hidden="true">↗</span>
                {b.description && <span class="bookmark-desc">{b.description}</span>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>
