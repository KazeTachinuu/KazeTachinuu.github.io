---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/PageHeader.astro';
import { BOOKMARKS } from '~/data/bookmarks';

const total = BOOKMARKS.reduce((n, c) => n + c.bookmarks.length, 0);
---

<Layout title="Bookmarks" mainClass="max-w-5xl mx-auto px-6 py-16">
  <PageHeader
    title="Bookmarks"
    section="bookmarks"
    description={`${total} single-purpose, open-source tools I actually use.`}
  />

  <div class="bm-grid">
    {BOOKMARKS.map((cat) => (
      <article class="bm-card">
        <header class="bm-card-head">
          <h2 class="bm-card-title">{cat.title}</h2>
          <span class="bm-card-count">{cat.bookmarks.length}</span>
        </header>
        <ul class="bm-card-list">
          {cat.bookmarks.map((b) => (
            <li>
              <a class="bm-link" href={b.url} target="_blank" rel="noopener noreferrer">
                <span class="bm-link-name">{b.name}</span>
                <span class="bm-link-arrow" aria-hidden="true">↗</span>
                {b.description && <span class="bm-link-desc">{b.description}</span>}
              </a>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</Layout>
