---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/PageHeader.astro';
import { BOOKMARKS } from '~/data/bookmarks';

const categories = Object.entries(BOOKMARKS);
const total = categories.reduce((n, [, items]) => n + items.length, 0);
---

<Layout title="Bookmarks" mainClass="max-w-7xl mx-auto px-6 py-20">
  <PageHeader
    title="Bookmarks"
    section="bookmarks"
    description={`${total} single-purpose, open-source tools I actually use.`}
  />

  <div class="bm-toolbar">
    <label class="bm-search-label" for="bookmark-search">Search bookmarks</label>
    <div class="bm-search-wrap">
      <svg aria-hidden="true" class="bm-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input id="bookmark-search" class="bm-search" type="search" placeholder="Search tools, categories, descriptions…" autocomplete="off" />
    </div>
    <p class="bm-search-count" aria-live="polite"><span id="bookmark-count">{total}</span> tools</p>
  </div>

  <div class="bm-grid" id="bookmark-grid">
    {categories.map(([title, bookmarks]) => (
      <article class="bm-card" data-bookmark-card data-category={title.toLowerCase()}>
        <header class="bm-card-head">
          <h2 class="bm-card-title">
            <span class="bm-card-dot" aria-hidden="true"></span>
            {title}
          </h2>
          <span class="bm-card-count" aria-label={`${bookmarks.length} tools`}>
            {bookmarks.length}
          </span>
        </header>
        <ul class="bm-card-list">
          {bookmarks.map((b) => (
            <li data-bookmark-item data-search={`${title} ${b.name} ${b.description ?? ''}`.toLowerCase()}>
              <a class="bm-link" href={b.url} target="_blank" rel="noopener noreferrer">
                <span class="bm-link-name">{b.name}</span>
                <span class="bm-link-arrow" aria-hidden="true">↗</span>
                {b.description && <span class="bm-link-desc">{b.description}</span>}
              </a>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>

  <p class="bm-empty" id="bookmark-empty" hidden>No bookmarks found. Try a different search.</p>

  <script>
    const search = document.querySelector<HTMLInputElement>('#bookmark-search');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-bookmark-card]'));
    const count = document.querySelector<HTMLElement>('#bookmark-count');
    const empty = document.querySelector<HTMLElement>('#bookmark-empty');

    search?.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        let cardVisible = false;
        const items = Array.from(card.querySelectorAll<HTMLElement>('[data-bookmark-item]'));

        for (const item of items) {
          const matches = !q || item.dataset.search?.includes(q) || card.dataset.category?.includes(q);
          item.hidden = !matches;
          if (matches) {
            visible += 1;
            cardVisible = true;
          }
        }

        card.hidden = !cardVisible;
      }

      if (count) count.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
    });
  </script>
</Layout>
