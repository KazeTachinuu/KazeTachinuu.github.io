---
import distrosData from "../../data/xz-distros.json";

interface Distro {
  id: string;
  name: string;
  icon: string;
  status: string;
  shipped: string;
  note: string | null;
}
interface StatusMeta {
  label: string;
  color: string;
}

const distros: Distro[] = distrosData.distros;
const statuses: Record<string, StatusMeta> = distrosData.statuses;

/* Inline SVGs at build time. Vite's ?raw query gives the file contents
   as a string - no runtime fetch, no extra HTTP. */
const icons = import.meta.glob("../../data/xz-icons/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

function iconFor(name: string): string {
  const k = Object.keys(icons).find((p) => p.endsWith(`/${name}`));
  return k ? icons[k] : '<svg viewBox="0 0 24 24"></svg>';
}

const order = ["exploitable", "shipped-inert", "spared"] as const;
const grouped = order.map((key) => ({
  key,
  meta: statuses[key],
  items: distros.filter((d) => d.status === key),
}));
---

<figure class="xz-widget xz-distros not-prose" aria-label="Distros affected by CVE-2024-3094">
  <div class="xz-distros-grid">
    {
      grouped.map(({ key, meta, items }) => (
        <section class="xz-distros-col" data-status={key}>
          <header class="xz-distros-col-head">
            <span class="xz-distros-col-label">{meta.label}</span>
            <span class="xz-distros-col-count">{items.length}</span>
          </header>
          <ol class="xz-distros-col-list">
            {items.map((d) => (
              <li class="xz-distros-item">
                <div class="xz-distros-item-head">
                  <span class="xz-distros-item-mark">
                    <span
                      class="xz-distros-item-icon"
                      aria-hidden="true"
                      set:html={iconFor(d.icon)}
                    />
                    <span class="xz-distros-item-name">{d.name}</span>
                  </span>
                  <span class="xz-distros-item-ver">{d.shipped}</span>
                </div>
                {d.note && <p class="xz-distros-item-note">{d.note}</p>}
              </li>
            ))}
          </ol>
        </section>
      ))
    }
  </div>
</figure>

<style>
  .xz-distros {
    margin-block: 2rem;
  }

  .xz-distros-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
  }

  .xz-distros-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .xz-distros-col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid currentColor;
  }
  .xz-distros-col[data-status="exploitable"] .xz-distros-col-head {
    color: var(--xz-attacker);
  }
  .xz-distros-col[data-status="shipped-inert"] .xz-distros-col-head {
    color: var(--xz-infra);
  }
  .xz-distros-col[data-status="spared"] .xz-distros-col-head {
    color: var(--xz-defender);
  }

  .xz-distros-col-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: var(--xz-tracking-caps);
    text-transform: uppercase;
  }
  .xz-distros-col-count {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }

  .xz-distros-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .xz-distros-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .xz-distros-item:last-child {
    border-bottom: 0;
  }

  .xz-distros-item-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .xz-distros-item-mark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    min-width: 0;
  }
  .xz-distros-item-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
    display: inline-flex;
    align-self: center;
    color: var(--muted);
    transition: color 0.15s ease;
  }
  .xz-distros-col[data-status="exploitable"] .xz-distros-item-icon {
    color: var(--xz-attacker);
  }
  .xz-distros-col[data-status="shipped-inert"] .xz-distros-item-icon {
    color: var(--xz-infra);
  }
  .xz-distros-col[data-status="spared"] .xz-distros-item-icon {
    color: var(--xz-defender);
  }
  .xz-distros-item-icon :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
  .xz-distros-item-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--page-text);
    line-height: 1.25;
  }
  .xz-distros-item-ver {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .xz-distros-item-note {
    margin: 0.3rem 0 0 1.45rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--text-secondary);
  }

  @media (max-width: 720px) {
    .xz-distros-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
    }
  }
</style>
